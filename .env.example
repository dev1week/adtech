DATABASE_URL=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-secret

# Seed default admin account (optional)
ADMIN_ID=admin
ADMIN_PASSWORD=admin1234

# Paste private key content as one-line value with \n escaping.
# Example: cat keys/private_key.pem | awk '{printf "%s\\n",$0}'
RSA_PRIVATE_KEY=
